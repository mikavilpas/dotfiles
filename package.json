{
  "name": "@dotfiles/root",
  "private": true,
  "description": "",
  "type": "module",
  "scripts": {
    "cy:run": "pnpm --filter ./integration-tests/ cy:run",
    "dev": "pnpm --filter ./integration-tests/ dev",
    "lint": "pnpx oxlint --type-aware && eslint --max-warnings=0 .",
    "prettier": "prettier --check .",
    "tui": "pnpm --filter ./integration-tests/ exec tui"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "eslint": "10.4.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-no-only-tests": "3.4.0",
    "eslint-plugin-oxlint": "1.66.0",
    "oxlint": "1.66.0",
    "oxlint-tsgolint": "0.23.0",
    "prettier": "3.8.3",
    "prettier-plugin-organize-imports": "4.3.0",
    "prettier-plugin-packagejson": "3.0.2",
    "typescript-eslint": "8.59.4"
  },
  "packageManager": "pnpm@11.2.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "core-js",
      "cypress",
      "esbuild",
      "node-pty",
      "puppeteer"
    ]
  }
}

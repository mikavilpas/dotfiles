{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "automerge": true,
  "extends": [
    "config:best-practices",
    "group:allNonMajor",
    "github>Turbo87/renovate-config//rust/updateToolchain",
    "local>mikavilpas/mika-renovate"
  ],
  "commitBodyTable": true,
  "packageRules": [
    {
      "matchUpdateTypes": ["digest"],
      "automerge": true,
      "automergeType": "branch"
    },
    {
      "matchPackageNames": ["gitlab-org/cli"],
      "overrideDatasource": "gitlab-releases"
    },
    {
      "description": [
        "https://github.com/fish-shell/fish-shell",
        "Its updates can be broken for a few days from time to time.",
        "Put them to a separate group to avoid blocking other updates."
      ],
      "matchDepNames": ["aqua:fish-shell/fish-shell"],
      "groupName": "fish-shell"
    },
    {
      "description": [
        "pnpm 11.12.0's self-installer crashes in pnpm/action-setup",
        "https://github.com/mikavilpas/dotfiles/actions/runs/29474716998/job/87545125670?pr=1420"
      ],
      "matchDepNames": ["pnpm"],
      "allowedVersions": "!/^11\\.12\\.0$/"
    },
    {
      "matchPackageNames": ["jdx/mise"],
      "allowedVersions": "!/2026\\.7\\.10/"
    }
  ]
}
